<h2>Your Bookings</h2>

<% bookings.forEach(b => { %>
  <div style="border:1px solid black; padding:15px; margin:10px;">
    
    <h3><%= b.listing.title %></h3>

    <p><b>Check In:</b> <%= b.checkIn.toDateString() %></p>
    <p><b>Check Out:</b> <%= b.checkOut.toDateString() %></p>

    <p><b>Total Price:</b> ₹<%= b.totalPrice %></p>

  </div>
<% }) %>